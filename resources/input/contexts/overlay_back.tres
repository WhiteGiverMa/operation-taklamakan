[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_key.gd" id="3_key"]
[ext_resource type="Script" path="res://addons/guide/guide_input_mapping.gd" id="4_input_mapping"]
[ext_resource type="Script" path="res://addons/guide/guide_action_mapping.gd" id="5_action_mapping"]
[ext_resource type="Script" path="res://addons/guide/triggers/guide_trigger_pressed.gd" id="6_pressed"]

[sub_resource type="Resource" id="EscapeKey"]
script = ExtResource("3_key")
