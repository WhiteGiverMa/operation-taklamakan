[gd_resource type="Resource" script_class="GUIDEMappingContext" load_steps=16 format=3]

[ext_resource type="Script" path="res://addons/guide/guide_mapping_context.gd" id="1_context"]
[ext_resource type="Resource" path="res://resources/input/actions/pause_toggle.tres" id="2_pause"]
[ext_resource type="Resource" path="res://resources/input/actions/map_pan_hold.tres" id="3_pan_hold"]
[ext_resource type="Resource" path="res://resources/input/actions/map_pan_delta.tres" id="4_pan_delta"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_key.gd" id="5_key"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_mouse_button.gd" id="6_mouse_button"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_mouse_axis_2d.gd" id="7_mouse_axis"]
[ext_resource type="Script" path="res://addons/guide/guide_input_mapping.gd" id="8_input_mapping"]
[ext_resource type="Script" path="res://addons/guide/guide_action_mapping.gd" id="9_action_mapping"]
[ext_resource type="Script" path="res://addons/guide/triggers/guide_trigger_pressed.gd" id="10_pressed"]

[sub_resource type="Resource" id="EscapeKey"]
script = ExtResource("5_key")
key = 4194305
allow_additional_modifiers = false

[sub_resource type="Resource" id="PauseTrigger"]
script = ExtResource("10_pressed")
actuation_threshold = 0.5

[sub_resource type="Resource" id="PauseMapping"]
script = ExtResource("8_input_mapping")
input = SubResource("EscapeKey")
modifiers = Array[Resource("res://addons/guide/modifiers/guide_modifier.gd")]([])
triggers = Array[Resource("res://addons/guide/triggers/guide_trigger.gd")]([SubResource("PauseTrigger")])

[sub_resource type="Resource" id="PauseActionMapping"]
script = ExtResource("9_action_mapping")
action = ExtResource("2_pause")
input_mappings = Array[ExtResource("8_input_mapping")]([SubResource("PauseMapping")])

[sub_resource type="Resource" id="MiddleMouse"]
script = ExtResource("6_mouse_button")
button = 3

[sub_resource type="Resource" id="PanHoldMapping"]
script = ExtResource("8_input_mapping")
input = SubResource("MiddleMouse")
modifiers = Array[Resource("res://addons/guide/modifiers/guide_modifier.gd")]([])
triggers = Array[Resource("res://addons/guide/triggers/guide_trigger.gd")]([])

[sub_resource type="Resource" id="PanHoldActionMapping"]
script = ExtResource("9_action_mapping")
action = ExtResource("3_pan_hold")
input_mappings = Array[ExtResource("8_input_mapping")]([SubResource("PanHoldMapping")])

[sub_resource type="Resource" id="MouseDelta"]
script = ExtResource("7_mouse_axis")

[sub_resource type="Resource" id="PanDeltaMapping"]
script = ExtResource("8_input_mapping")
input = SubResource("MouseDelta")
modifiers = Array[Resource("res://addons/guide/modifiers/guide_modifier.gd")]([])
triggers = Array[Resource("res://addons/guide/triggers/guide_trigger.gd")]([])

[sub_resource type="Resource" id="PanDeltaActionMapping"]
script = ExtResource("9_action_mapping")
action = ExtResource("4_pan_delta")
input_mappings = Array[ExtResource("8_input_mapping")]([SubResource("PanDeltaMapping")])

[resource]
script = ExtResource("1_context")
display_name = "Map"
mappings = Array[ExtResource("9_action_mapping")]([SubResource("PauseActionMapping"), SubResource("PanHoldActionMapping"), SubResource("PanDeltaActionMapping")])
